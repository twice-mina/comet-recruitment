rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ============================================
    // HELPER FUNCTIONS
    // ============================================

    // Check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }

    // Check if user owns the document (document has userId field)
    function isOwner() {
      return isAuthenticated() &&
             resource.data.userId == request.auth.uid;
    }

    // Check if user is creating a document they will own
    function isCreatingOwned() {
      return isAuthenticated() &&
             request.resource.data.userId == request.auth.uid;
    }

    // Check if user is admin (check in userProfiles or users collection)
    function isAdmin() {
      return isAuthenticated() && (
        (exists(/databases/$(database)/documents/userProfiles/$(request.auth.uid)) &&
         get(/databases/$(database)/documents/userProfiles/$(request.auth.uid)).data.role == 'admin') ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin')
      );
    }

    // ============================================
    // USER PROFILES
    // ============================================

    // User profiles - users can read/write their own profile
    match /userProfiles/{userId} {
      allow read: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
      allow create: if isAuthenticated() && request.auth.uid == userId;
      allow update: if isAuthenticated() && request.auth.uid == userId;
      allow delete: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
    }

    // Users collection (alternative to userProfiles)
    match /users/{userId} {
      allow read: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
      allow create: if isAuthenticated() && request.auth.uid == userId;
      allow update: if isAuthenticated() && request.auth.uid == userId;
      allow delete: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
    }

    // ============================================
    // USER-OWNED COLLECTIONS
    // ============================================
    // Pattern: Documents with a userId field belong to that user

    // Generic pattern for user-owned collections
    // Add your collection names here or use the wildcard pattern below

    // Contacts
    match /contacts/{contactId} {
      allow read: if isOwner() || isAdmin();
      allow create: if isCreatingOwned();
      allow update: if isOwner() || isAdmin();
      allow delete: if isOwner() || isAdmin();
    }

    // Settings
    match /settings/{settingId} {
      allow read: if isOwner() || isAdmin();
      allow create: if isCreatingOwned();
      allow update: if isOwner() || isAdmin();
      allow delete: if isOwner() || isAdmin();
    }

    // ============================================
    // SUBCOLLECTIONS
    // ============================================

    // User subcollections (e.g., /userProfiles/{userId}/tokens)
    match /userProfiles/{userId}/{subcollection}/{docId} {
      allow read, write: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
    }

    match /users/{userId}/{subcollection}/{docId} {
      allow read, write: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
    }

    // ============================================
    // ADMIN-ONLY COLLECTIONS
    // ============================================

    match /adminData/{docId} {
      allow read, write: if isAdmin();
    }

    match /systemConfig/{docId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // ============================================
    // PUBLIC COLLECTIONS (if needed)
    // ============================================

    // Public content that anyone can read
    match /publicContent/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
