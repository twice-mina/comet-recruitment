# ============================================
# EMAIL SPLIT TEST - ENVIRONMENT VARIABLES
# ============================================
# Copy this file to .env.local and fill in your values
# ============================================

# ============================================
# APP CONFIGURATION
# ============================================
NEXT_PUBLIC_APP_NAME="Email Split Test"
NEXT_PUBLIC_APP_DESCRIPTION="Email split testing application"
NEXT_PUBLIC_APP_URL=https://your-domain.com

# ============================================
# FIREBASE CONFIGURATION
# ============================================
# Get these values from Firebase Console > Project Settings > General > Your apps
NEXT_PUBLIC_FIREBASE_API_KEY=your-api-key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project-id.firebasestorage.app
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your-sender-id
NEXT_PUBLIC_FIREBASE_APP_ID=your-app-id

# Google Cloud Project ID (usually same as Firebase project ID)
GOOGLE_CLOUD_PROJECT=your-project-id

# ============================================
# GOOGLE OAUTH
# ============================================
# Get these from Google Cloud Console > APIs & Services > Credentials
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret

# ============================================
# DEVELOPMENT ONLY
# ============================================
# Path to Firebase Admin SDK service account JSON (local development only)
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json
